# https://editorconfig.org
root = true

# =============================================================================
# Глобальные настройки по умолчанию
# =============================================================================
[*]
charset = utf-8
end_of_line = lf
insert_final_newline = true
trim_trailing_whitespace = true
indent_style = space
indent_size = 4

# =============================================================================
# Python файлы — 4 пробела (PEP 8)
# =============================================================================
[*.py]
indent_size = 4
max_line_length = 127

# =============================================================================
# SQL файлы — 2 пробела (как ты хочешь) ✅
# =============================================================================
[*.sql]
indent_size = 2
indent_style = space

# =============================================================================
# Jinja2 шаблоны (миграции) — 2 пробела
# =============================================================================
[*.j2]
indent_size = 2
indent_style = space

# =============================================================================
# Markdown / YAML / JSON — 2 пробела
# =============================================================================
[*.{md,yaml,yml,json}]
indent_size = 2

# =============================================================================
# Shell scripts — 2 пробела
# =============================================================================
[*.sh]
indent_size = 2

# =============================================================================
# Исключения — не форматировать
# =============================================================================
[**/{.git,.venv,venv,dist,build,node_modules}/**]
indent_size = unset
